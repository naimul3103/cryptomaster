# CryptoMaster Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

DB_HOST=127.0.0.1
DB_NAME=cryptomaster
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Admin seed account (used only on first run / schema init)
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=change_me_immediately

# Application
APP_ENV=production
APP_URL=https://yourdomain.com
